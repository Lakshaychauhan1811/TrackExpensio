# Copy to .env and fill in your values (never commit .env)

# ── Required ──────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=ai_expense_tracker
GROQ_API_KEY=your_groq_api_key

# ── Server (Render sets PORT automatically) ───────────────────────────
FASTAPI_HOST=127.0.0.1
FASTAPI_PORT=8080
# ALLOWED_ORIGINS=http://127.0.0.1:8080,https://your-app.onrender.com

# ── Google OAuth ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://127.0.0.1:8080/auth/google/callback
GOOGLE_PROJECT_ID=your_project_id

# ── AI model overrides ────────────────────────────────────────────────
GROQ_AGENT_MODEL=llama-3.3-70b-versatile
GROQ_RAG_MODEL=llama-3.3-70b-versatile

# ── Timezone ──────────────────────────────────────────────────────────
APP_TIMEZONE=Asia/Kolkata

# ── Voice (cloud Whisper — no local PyTorch needed) ───────────────────
OPENAI_API_KEY=

# ── Stock analyzer live news (optional) ───────────────────────────────
SERPER_API_KEY=

# ── Plaid bank sync (US/UK/EU — optional) ────────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_DAYS_REQUESTED=90
PLAID_COUNTRY_CODES=US

# ── India Account Aggregator (sandbox works without keys) ─────────────
# SETU_API_KEY=
# FINVU_API_KEY=

# ── Email bill alerts (optional) ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
BILL_REMINDER_DAYS=7,3,1,0
BILL_REMINDER_INTERVAL_SEC=3600

# ── Push notifications (optional) ─────────────────────────────────────
FCM_SERVER_KEY=
